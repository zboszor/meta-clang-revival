Date: Wed, 8 Apr 2026 17:02:26 +0200
Subject: [PATCH] Set libcxxabi soversion externally
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Signed-off-by: Zoltán Böszörményi <zboszor@gmail.com>
Upstream-Status: Inappropriate
---
 libcxxabi/src/CMakeLists.txt | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/libcxxabi/src/CMakeLists.txt b/libcxxabi/src/CMakeLists.txt
index 0a6fc892a4f6..68aecdf52ce9 100644
--- a/libcxxabi/src/CMakeLists.txt
+++ b/libcxxabi/src/CMakeLists.txt
@@ -200,7 +200,7 @@ set_target_properties(cxxabi_shared
     EXCLUDE_FROM_ALL "$<IF:$<BOOL:${LIBCXXABI_ENABLE_SHARED}>,FALSE,TRUE>"
     LINK_FLAGS "${LIBCXXABI_LINK_FLAGS}"
     OUTPUT_NAME "${LIBCXXABI_SHARED_OUTPUT_NAME}"
-    SOVERSION "1"
+    SOVERSION "${LIBCXXABI_MAJOR_VERSION}"
     VERSION "${LIBCXXABI_LIBRARY_VERSION}"
 )
 
